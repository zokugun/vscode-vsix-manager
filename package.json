{
	"name": "vsix-manager",
	"displayName": "VSIX Manager",
	"description": "Install extensions from your own sources",
	"version": "0.12.0",
	"author": {
		"name": "Baptiste Augrain",
		"email": "daiyam@zokugun.org"
	},
	"publisher": "zokugun",
	"license": "MIT",
	"homepage": "https://github.com/zokugun/vscode-vsix-manager",
	"repository": {
		"type": "git",
		"url": "https://github.com/zokugun/vscode-vsix-manager.git"
	},
	"bugs": {
		"url": "https://github.com/zokugun/vscode-vsix-manager/discussions/categories/issue-triage"
	},
	"engines": {
		"vscode": "^1.56.0"
	},
	"main": "./lib/index.js",
	"browser": "./lib/index.js",
	"scripts": {
		"audit:fix": "npm audit fix --min-release-age=0",
		"build": "npm run clean && npm run compile:src && npm run bundle",
		"bundle": "ncc build out/extension --out lib --external sql.js",
		"ci:lint": "zizmor .",
		"ci:lint:fix": "zizmor . --fix=all",
		"clean": "rimraf lib out *.vsix",
		"compile:src": "tsc -p src",
		"lint": "xo",
		"lint:all": "npm audit && npm run lint:package && npm run ci:lint && npm run lint",
		"lint:fix": "xo --fix",
		"lint:package": "fixpack || true",
		"package": "rimraf *.vsix && vsce package",
		"prepare": "husky; npm run lint:package",
		"release": "release-it",
		"update:artifacts": "artifact update",
		"update:ci": "PINACT_MIN_AGE=7 pinact run --update",
		"update:deps": "taze --all",
		"vscode:prepublish": "npm run build",
		"watch:src": "tsc-watch -p src --onSuccess 'npm run bundle'"
	},
	"dependencies": {
		"@zokugun/fs-extra-plus": "0.4.1",
		"@zokugun/is-it-type": "0.8.1",
		"@zokugun/vscode-utils": "0.3.1",
		"@zokugun/xtry": "0.11.5",
		"@zokugun/yauzl-plus": "0.1.1",
		"globby": "11.1.0",
		"got": "11.8.6",
		"semver": "7.7.4",
		"sql.js": "1.14.1"
	},
	"devDependencies": {
		"@commitlint/cli": "20.5.3",
		"@commitlint/config-conventional": "20.5.3",
		"@types/node": "20.19.43",
		"@types/semver": "7.7.1",
		"@types/sql.js": "1.4.11",
		"@types/vscode": "1.56.0",
		"@vercel/ncc": "0.44.0",
		"@vscode/vsce": "3.9.2",
		"fixpack": "4.0.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"release-it": "20.2.0",
		"rimraf": "6.1.3",
		"taze": "19.14.1",
		"tsc-watch": "7.2.0",
		"typescript": "5.9.3",
		"xo": "0.60.0"
	},
	"overrides": {
		"release-it": {
			"undici": "7.28.0"
		}
	},
	"allowScripts": {
		"@vscode/vsce-sign": true,
		"keytar": true
	},
	"extensionDependencies": [
		"zokugun.cron-tasks"
	],
	"activationEvents": [
		"onStartupFinished",
		"onCommand:vsix.installExtensions",
		"onCommand:vsix.uninstallExtensions",
		"onCommand:vsix.updateExtensions"
	],
	"capabilities": {
		"virtualWorkspaces": true,
		"untrustedWorkspaces": {
			"supported": true
		}
	},
	"contributes": {
		"commands": [
			{
				"command": "vsix.adoptExtensions",
				"title": "Adopt unmanaged extensions",
				"category": "VSIX Manager"
			},
			{
				"command": "vsix.installExtensions",
				"title": "Synchronize extensions",
				"category": "VSIX Manager"
			},
			{
				"command": "vsix.uninstallExtensions",
				"title": "Uninstall extensions",
				"category": "VSIX Manager"
			},
			{
				"command": "vsix.updateExtensions",
				"title": "Update only installed extensions",
				"category": "VSIX Manager"
			}
		],
		"configuration": {
			"title": "VSIX Manager",
			"properties": {
				"vsix.crons": {
					"type": "object",
					"description": "Automate some commands",
					"properties": {
						"update": {
							"type": "string",
							"description": "Automatically update the extensions at the specified time",
							"default": ""
						}
					},
					"default": {},
					"scope": "application",
					"tags": [
						"vsix"
					]
				},
				"vsix.debug": {
					"type": "boolean",
					"description": "Output debug logs",
					"default": false,
					"scope": "application",
					"tags": [
						"vsix"
					]
				},
				"vsix.extensions": {
					"type": "array",
					"description": "List of extension IDs or groups to install",
					"items": [
						{
							"type": "string"
						},
						{
							"type": "object",
							"properties": {
								"id": {
									"type": [
										"string",
										"array"
									]
								},
								"enabled": {
									"type": "boolean",
									"default": true
								}
							}
						},
						{
							"type": "array",
							"items": [
								{
									"type": "string"
								}
							]
						}
					],
					"default": [],
					"scope": "application",
					"uniqueItems": true,
					"tags": [
						"vsix"
					]
				},
				"vsix.groups": {
					"type": "object",
					"description": "Map of groups",
					"items": [
						{
							"type": "array",
							"description": "List of extension IDs or groups to install",
							"items": [
								{
									"type": "string"
								},
								{
									"type": "object",
									"properties": {
										"id": {
											"type": [
												"string",
												"array"
											]
										},
										"enabled": {
											"type": "boolean",
											"default": true
										}
									}
								},
								{
									"type": "array",
									"items": [
										{
											"type": "string"
										}
									]
								}
							]
						}
					],
					"default": {},
					"scope": "application",
					"uniqueItems": true,
					"tags": [
						"vsix"
					]
				},
				"vsix.notification": {
					"type": "string",
					"description": "Display notification when a new version is installed",
					"default": "minor",
					"enum": [
						"none",
						"major",
						"minor",
						"patch"
					],
					"enumDescriptions": [
						"The new version notification won't be shown anymore",
						"The new version notification will be shown only with a new major version",
						"The new version notification will be shown only with a new minor version",
						"The new version notification will always be shown"
					],
					"scope": "application",
					"tags": [
						"vsix"
					]
				},
				"vsix.restart.confirm": {
					"type": "boolean",
					"description": "Confirm with the user that the editor might restart or reload.",
					"default": true,
					"scope": "application",
					"tags": [
						"vsix"
					]
				},
				"vsix.restart.mode": {
					"type": "string",
					"description": "Select how to restart the extension host (only for advanced users, should be left on 'auto')",
					"default": "auto",
					"enum": [
						"auto",
						"none",
						"reload-windows",
						"restart-app",
						"restart-host"
					],
					"enumDescriptions": [
						"Select the best action",
						"Do nothing",
						"Reload the window",
						"Restart the extension host",
						"Restart the app"
					],
					"scope": "application",
					"tags": [
						"vsix"
					]
				},
				"vsix.showErrorAlert": {
					"type": "boolean",
					"description": "Show an alert when an error occurs.",
					"default": true,
					"scope": "application",
					"tags": [
						"vsix"
					]
				},
				"vsix.sources": {
					"type": "object",
					"description": "Map of sources from which to find the VSIX files",
					"items": [
						{
							"type": "object",
							"description": "A source",
							"properties": {
								"type": {
									"type": "string",
									"default": "marketplace",
									"enum": [
										"file",
										"marketplace"
									]
								},
								"path": {
									"type": "string",
									"description": "The path of the directory where the extensions are stored"
								},
								"serviceUrl": {
									"type": "string",
									"description": "The url of the service API"
								},
								"fallback": {
									"type": "string",
									"description": "Use the given source if an extension can't be found at the current source"
								},
								"throttle": {
									"type": "integer",
									"description": "The delay between each query (ms)",
									"default": 0
								}
							}
						}
					],
					"default": {},
					"scope": "application",
					"uniqueItems": true,
					"tags": [
						"vsix"
					]
				}
			}
		}
	},
	"icon": "icon.png",
	"galleryBanner": {
		"color": "#303B45",
		"theme": "dark"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"extension",
		"marketplace",
		"vsix"
	],
	"extensionKind": [
		"ui",
		"workspace"
	]
}
